{
  "name": "le-botteghe-matera",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/sync-prisma-provider.mjs && prisma generate && next dev",
    "build": "node scripts/sync-prisma-provider.mjs && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "node scripts/sync-prisma-provider.mjs && prisma generate",
    "db:push": "node scripts/sync-prisma-provider.mjs && prisma db push",
    "db:migrate": "node scripts/sync-prisma-provider.mjs && prisma migrate deploy",
    "db:seed": "node scripts/sync-prisma-provider.mjs && prisma generate && node prisma/seed.mjs",
    "db:studio": "node scripts/sync-prisma-provider.mjs && prisma studio",
    "setup": "npm install && npm run db:push && npm run db:seed"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "jose": "^5.9.6",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.7.2"
  }
}
